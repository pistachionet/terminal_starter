#!/usr/bin/env bash
# create — spin up a tmux workspace in the current directory
# Usage: navigate to a project directory, then run `create`
#
# Customize AGENT_CMD below to set your preferred coding tool for window 2.
# Set to empty string "" to skip window 2 entirely (terminal + yazi only).
# Examples:
#   AGENT_CMD="opencode"
#   AGENT_CMD="gh copilot"
#   AGENT_CMD="aider"
#   AGENT_CMD=""          # terminal + yazi only, no agent window

AGENT_CMD="opencode"  # <-- set your agent tool here, or leave empty for no agent window

SESSION_NAME=$(basename "$PWD" | tr '.' '_')

# If already inside tmux, bail
if [ -n "$TMUX" ]; then
  echo "Already in a tmux session."
  exit 1
fi

# Attach if session already exists
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  tmux attach-session -t "$SESSION_NAME"
  exit 0
fi

# Window 0: terminal (persistent anchor — keeps session alive)
tmux new-session -d -s "$SESSION_NAME" -n "terminal" -c "$PWD"

# Window 1: yazi
tmux new-window -t "$SESSION_NAME" -n "yazi" -c "$PWD" "yazi"

# Window 2: agent tool (optional)
if [ -n "$AGENT_CMD" ]; then
  tmux new-window -t "$SESSION_NAME" -n "agent" -c "$PWD"
  tmux send-keys -t "$SESSION_NAME:agent" "$AGENT_CMD" Enter
  tmux select-window -t "$SESSION_NAME:2"
else
  tmux select-window -t "$SESSION_NAME:0"
fi

# Attach
tmux attach-session -t "$SESSION_NAME"
